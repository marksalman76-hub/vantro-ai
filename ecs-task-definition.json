{
  "family": "trance-formation-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "trance-formation-backend",
      "image": "685570573617.dkr.ecr.ap-southeast-2.amazonaws.com/trance-formation-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
     "environment": [
  {
    "name": "DATABASE_URL",
    "value": "postgresql://postgres:Jessica2007!@localhost:5432/multi_industrial_dev"
  },
  {
    "name": "STRIPE_SECRET_KEY",
    "value": "sk_test_placeholder"
  },
  {
    "name": "STRIPE_WEBHOOK_SECRET",
    "value": "whsec_placeholder"
  },
  {
    "name": "ENVIRONMENT",
    "value": "production"
  },
  {
    "name": "LOG_LEVEL",
    "value": "info"
  }
],
      
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trance-formation-backend",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::685570573617:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::685570573617:role/trance-formation-task-role",
  "tags": [
    {
      "key": "Environment",
      "value": "production"
    },
    {
      "key": "Application",
      "value": "trance-formation"
    }
  ]
}
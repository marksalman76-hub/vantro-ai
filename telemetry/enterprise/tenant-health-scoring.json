{
  "script": "tenants/health-scoring",
  "status": "TENANT_HEALTH_SCORING_READY",
  "env": "production",
  "signals": [
    "usage",
    "risk",
    "churn",
    "production"
  ],
  "live_runtime_changed": false,
  "customer_safe": true,
  "scoring": {
    "usage_signal_enabled": true,
    "risk_signal_enabled": true,
    "churn_signal_enabled": true,
    "score_range": "0-100",
    "owner_review_required_for_high_risk_actions": true
  },
  "sample_result": {
    "tenant_id": "sample_tenant",
    "health_score": 82,
    "risk_level": "low",
    "churn_risk": "low",
    "recommended_action": "monitor"
  }
}
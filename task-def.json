{
  "family": "trance-formation-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::685570573617:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::685570573617:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "685570573617.dkr.ecr.us-east-1.amazonaws.com/trance-formation/api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/database-url-hVRSA3"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/jwt-secret-key-V3I8EA"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/stripe-secret-key-dtMsFT"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/stripe-webhook-secret-vIY8hj"
        },
        {
          "name": "STRIPE_PUBLISHABLE_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/stripe-publishable-key-N6oOkz"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/redis-url-BzFk4o"
        },
        {
          "name": "SQS_JOBS_QUEUE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/sqs-jobs-queue-url-Bxxbtu"
        },
        {
          "name": "HIGGSFIELD_MCP_CREDENTIALS_JSON",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/higgsfield-mcp-credentials-json-uvxgjA"
        },
        {
          "name": "ELEVENLABS_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/elevenlabs-api-key-lc7jgp"
        },
        {
          "name": "CLAUDE_CODE_OAUTH_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/claude-code-oauth-token-yXGWVN"
        },
        {
          "name": "HIGGSFIELD_CLAUDE_MCP_OAUTH_JSON",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/higgsfield-claude-mcp-oauth-json-wwp4lp"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/openai-api-key-dsCL3D"
        },
        {
          "name": "SENTRY_DSN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/sentry-dsn-ZI0RuC"
        }
      ],
      "environment": [
        { "name": "ENVIRONMENT",    "value": "production" },
        { "name": "PORT",           "value": "8000" },
        { "name": "FRONTEND_URL",   "value": "https://www.vantro.ai" },
        { "name": "FROM_EMAIL",     "value": "noreply@vantro.ai" },
        { "name": "AWS_REGION",     "value": "us-east-1" },
        { "name": "ADMIN_EMAIL",    "value": "mark.salman76@gmail.com" },
        { "name": "HIGGSFIELD_EXECUTION_SURFACE", "value": "claude_code_mcp" },
        { "name": "HIGGSFIELD_LIVE_EXECUTION_ENABLED", "value": "true" },
        { "name": "HIGGSFIELD_MCP_MAX_BUDGET_USD", "value": "5.00" },
        { "name": "HIGGSFIELD_MCP_READINESS_BUDGET_USD", "value": "1.00" },
        { "name": "ELEVENLABS_MODEL_ID", "value": "eleven_multilingual_v2" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 45
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trance-formation/api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}

NODE_ENV=production
PORT=3000
LOG_LEVEL=info
AWS_REGION=us-east-1

# ── LLM Provider (one or both required for live agent execution) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Agent Worker Control ──
# Set to "true" to allow live LLM calls (also requires at least one API key above)
ENABLE_LIVE_LLM_CALLS=true

{
  "family": "vantro-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::685570573617:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::685570573617:role/vantro-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "685570573617.dkr.ecr.us-east-1.amazonaws.com/trance-formation/worker:latest",
      "essential": true,
      "secrets": [
        { "name": "DATABASE_URL",        "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:DATABASE_URL" },
        { "name": "HEYGEN_API_KEY",      "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:HEYGEN_API_KEY" },
        { "name": "REDIS_URL",           "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:REDIS_URL" },
        { "name": "SQS_JOBS_QUEUE_URL",  "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:SQS_JOBS_QUEUE_URL" }
      ],
      "environment": [
        { "name": "AWS_REGION", "value": "us-east-1" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vantro/worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}

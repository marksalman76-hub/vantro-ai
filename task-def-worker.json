{
  "family": "vantro-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::685570573617:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::685570573617:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "685570573617.dkr.ecr.us-east-1.amazonaws.com/trance-formation/worker:latest",
      "essential": true,
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/database-url-hVRSA3"
        },
        {
          "name": "HEYGEN_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/heygen-api-key-xXjKuR"
        },
        {
          "name": "SQS_JOBS_QUEUE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/sqs-jobs-queue-url-Bxxbtu"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:685570573617:secret:vantro/prod/redis-url-BzFk4o"
        }
      ],
      "environment": [
        { "name": "AWS_REGION",    "value": "us-east-1" },
        { "name": "ENVIRONMENT",   "value": "production" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python3 -c \"import sys; sys.exit(0)\""],
        "interval": 60,
        "timeout": 10,
        "retries": 2,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vantro/worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}

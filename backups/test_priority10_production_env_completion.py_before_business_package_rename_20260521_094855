import json
import requests

BASE = "http://127.0.0.1:8000"
HEADERS = {
    "x-actor-role": "admin",
    "x-tenant-id": "owner",
    "Content-Type": "application/json",
}

def show(label, response):
    print("\n" + "=" * 80)
    print(label)
    print("HTTP", response.status_code)
    try:
        print(json.dumps(response.json(), indent=2)[:12000])
    except Exception:
        print(response.text[:12000])

stripe_readiness = requests.get(
    f"{BASE}/billing/stripe-production-readiness",
    headers=HEADERS,
    timeout=30,
)
show("STRIPE_PRODUCTION_READINESS", stripe_readiness)

live_readiness = requests.get(
    f"{BASE}/billing/live-stripe-readiness",
    headers=HEADERS,
    timeout=30,
)
show("LIVE_STRIPE_READINESS", live_readiness)

payload = {
    "tenant_id": "tenant_priority10_env_completion_test",
    "client_number": "CL-P10-ENV",
    "customer_email": "sale@protekepoxy.com.au",
    "target_package": "professional",
    "purchased_agents": [
        "head_agent",
        "marketing_specialist_agent",
        "crm_ai_agent",
        "ugc_creative_agent",
        "product_image_agent"
    ],
    "active_agents": [
        "head_agent",
        "marketing_specialist_agent",
        "ugc_creative_agent",
        "product_image_agent"
    ],
}

checkout = requests.post(
    f"{BASE}/billing/live-checkout-session",
    headers=HEADERS,
    json=payload,
    timeout=30,
)
show("LIVE_CHECKOUT_SESSION_READINESS", checkout)

stripe_json = stripe_readiness.json()
live_json = live_readiness.json()
checkout_json = checkout.json()

assert stripe_readiness.status_code == 200
assert live_readiness.status_code == 200
assert checkout.status_code == 200

assert stripe_json["success"] is True
assert live_json["success"] is True
assert checkout_json["success"] is True
assert stripe_json["secret_values_exposed"] is False
assert live_json["secret_exposure"] is False
assert checkout_json["secret_exposure"] is False

missing = set(stripe_json.get("missing_keys", [])) | set(live_json.get("missing_price_keys", []))

print("\nPRODUCTION_ENV_MISSING_KEYS", sorted(missing))

if stripe_json.get("production_ready") and live_json.get("live_stripe_ready"):
    assert checkout_json.get("mode") == "live_stripe"
    assert checkout_json.get("checkout_session_created") is True
    print("\nPRIORITY10_PRODUCTION_ENV_COMPLETION_OK")
else:
    assert checkout_json.get("mode") == "safe_fallback"
    print("\nPRIORITY10_PRODUCTION_ENV_STILL_NEEDS_CONFIG")